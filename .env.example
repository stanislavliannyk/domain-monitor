APP_NAME="Domain Monitor"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_PORT=8080
DB_EXTERNAL_PORT=33060
MAILPIT_UI_PORT=9025
MAILPIT_SMTP_PORT=9001

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=domain_monitor
DB_USERNAME=domain_monitor
DB_PASSWORD=secret

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@domain-monitor.local"
MAIL_FROM_NAME="${APP_NAME}"

CHECK_INTERVAL_DEFAULT=5
CHECK_TIMEOUT_DEFAULT=10
